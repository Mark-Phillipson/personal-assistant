ASSISTANT_TRANSPORT=telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_POLL_TIMEOUT_SECONDS=25
TELEGRAM_ERROR_BACKOFF_SECONDS=3
TELEGRAM_ATTACHMENT_STORAGE_PATH=
TELEGRAM_ATTACHMENT_MAX_BYTES=20971520

# Gmail integration (optional)
GMAIL_CLIENT_SECRET_PATH=secrets\gmail-client-secret.json
GMAIL_TOKEN_STORE_PATH=.gmail-token-store
GMAIL_EXPECTED_ACCOUNT_EMAIL=MPhillipson0@gmail.com

# Google Calendar integration (optional)
CALENDAR_CLIENT_SECRET_PATH=secrets\calendar-client-secret.json
CALENDAR_TOKEN_STORE_PATH=.calendar-token-store
CALENDAR_EXPECTED_ACCOUNT_EMAIL=your@email.com

# NaturalCommands integration (optional)
NATURAL_COMMANDS_EXECUTABLE=natural
NATURAL_COMMANDS_WORKING_DIRECTORY=
NATURAL_COMMANDS_TIMEOUT_SECONDS=15

# Voice Admin integration (optional)
VOICE_ADMIN_DB_PATH=
VOICE_ADMIN_MAX_RESULTS=20

# Legacy fallbacks (optional)
VOICE_LAUNCHER_DB_PATH=
VOICE_LAUNCHER_MAX_RESULTS=20

# Text-to-speech (optional)
ASSISTANT_TTS_ENABLED=false
ASSISTANT_TTS_PREVIEW_MAX_WORDS=40
ASSISTANT_TTS_PREFERRED_GENDER=male
